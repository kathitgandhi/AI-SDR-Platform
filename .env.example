# ============================================================
# AI SDR PLATFORM — ENVIRONMENT CONFIGURATION
# Copy to .env and fill all values before deployment
# ============================================================

# ---- APPLICATION ----
NODE_ENV=production
PORT=3000
API_SECRET_KEY=your-256-bit-secret-key-here
WEBHOOK_SECRET=your-webhook-signing-secret-here
ALLOWED_ORIGINS=https://your-dashboard.com

# ---- SUPABASE ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ---- REDIS (Upstash or self-hosted) ----
REDIS_URL=rediss://default:password@your-redis.upstash.io:6380
REDIS_MAX_RETRIES=3

# ---- ZOOMINFO ----
ZOOMINFO_CLIENT_ID=your-client-id
ZOOMINFO_CLIENT_SECRET=your-client-secret
ZOOMINFO_BASE_URL=https://api.zoominfo.com/lookup
ZOOMINFO_RATE_LIMIT_RPM=100

# ---- TWILIO ----
# Voice number is imported into ElevenLabs (it places/answers calls via Twilio).
# Backend uses Twilio directly only for SMS + phone-number lookup.
# NOTE: never paste the Auth Token into chat/screenshots — set it here only.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+12025551234
# Optional: use a Messaging Service instead of a bare From number
TWILIO_MESSAGING_SERVICE_SID=

# ---- ELEVENLABS ----
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_BASE_URL=https://api.elevenlabs.io/v1
# Phone number id (phnum_...) of the Twilio number imported into ElevenLabs.
ELEVENLABS_PHONE_NUMBER_ID=phnum_xxxxxxxxxxxxxxxxxxxxxxxx
# HMAC secret for ElevenLabs conversation-init / post-call webhooks (set in portal).
ELEVENLABS_WEBHOOK_SECRET=your-elevenlabs-webhook-secret
# Agent IDs per persona — create in ElevenLabs dashboard
ELEVENLABS_AGENT_MIKE=agent_mike_id
ELEVENLABS_AGENT_SARAH=agent_sarah_id
ELEVENLABS_AGENT_DAVID=agent_david_id
ELEVENLABS_AGENT_RACHEL=agent_rachel_id
ELEVENLABS_AGENT_CHRIS=agent_chris_id
ELEVENLABS_AGENT_EMMA=agent_emma_id
ELEVENLABS_AGENT_DANIEL=agent_daniel_id

# ---- ANTHROPIC ----
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-opus-4-7
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_REASONING_BUDGET=2048

# ---- GMAIL ----
GMAIL_CLIENT_ID=your-google-oauth-client-id
GMAIL_CLIENT_SECRET=your-google-oauth-client-secret
GMAIL_REFRESH_TOKEN=your-refresh-token
GMAIL_FROM_ADDRESS=outreach@yourcompany.com
GMAIL_FROM_NAME=Your Company Sales Team
GMAIL_CC_HOT_LEADS=sales-team@yourcompany.com

# ---- CRM INTEGRATIONS (optional — enable as needed) ----
CRM_PROVIDER=hubspot
# Options: hubspot | salesforce | pipedrive | zoho | none

HUBSPOT_ACCESS_TOKEN=your-hubspot-token
HUBSPOT_PORTAL_ID=your-portal-id

SALESFORCE_CLIENT_ID=your-sf-client-id
SALESFORCE_CLIENT_SECRET=your-sf-client-secret
SALESFORCE_REFRESH_TOKEN=your-sf-refresh-token
SALESFORCE_INSTANCE_URL=https://yourorg.salesforce.com

PIPEDRIVE_API_KEY=your-pipedrive-key
PIPEDRIVE_COMPANY_DOMAIN=yourcompany

ZOHO_CLIENT_ID=your-zoho-client-id
ZOHO_CLIENT_SECRET=your-zoho-client-secret
ZOHO_REFRESH_TOKEN=your-zoho-refresh-token

# ---- COMPANY IDENTITY (used in AI disclosure) ----
COMPANY_NAME=AirRetail Technologies
COMPANY_WEBSITE=https://yourcompany.com
SALES_TEAM_EMAIL=sales@yourcompany.com
SUPPORT_EMAIL=support@yourcompany.com

# ---- CALL ENGINE ----
CALL_MAX_CONCURRENT=10
CALL_RETRY_MAX_ATTEMPTS=3
CALL_RETRY_DELAY_MINUTES=60
CALL_MAX_DURATION_SECONDS=600
CALL_RING_TIMEOUT_SECONDS=30
CALL_PACING_DELAY_MS=2000

# ---- VOICE COST RATES (USD per minute) ----
# Multiplied by each call's billed duration and recorded into api_usage
# (entity_type='call') so the call-detail endpoint can report an all-in total
# per call. Override with your actual plan rates.
ELEVENLABS_COST_PER_MINUTE_USD=0.10
TWILIO_VOICE_COST_PER_MINUTE_USD=0.014

# ---- COMPLIANCE ----
CALL_WINDOW_START_HOUR=8
CALL_WINDOW_END_HOUR=21
ENABLE_DNC_FEDERAL=true
ENABLE_DNC_STATE=true
AI_DISCLOSURE_REQUIRED=true

# ---- SENTRY (error monitoring) ----
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ---- RATE LIMITING ----
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ---- REPORTING ----
DAILY_DIGEST_CRON=0 7 * * *
WEEKLY_DIGEST_CRON=0 8 * * 1
REPORT_RECIPIENTS=management@yourcompany.com,sales@yourcompany.com

# ---- MCP SERVER ----
MCP_PORT=3001
MCP_AUTH_TOKEN=your-mcp-auth-token-here
