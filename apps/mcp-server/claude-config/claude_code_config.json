{
  "_comment": "Add to .claude/settings.json in your project root (or ~/.claude/settings.json for global)",
  "_doc": "https://docs.anthropic.com/en/docs/claude-code/mcp",

  "mcpServers": {
    "ai-sdr-platform": {
      "type": "stdio",
      "command": "node",
      "args": ["apps/mcp-server/dist/server.js"],
      "env": {
        "SUPABASE_URL": "${SUPABASE_URL}",
        "SUPABASE_SERVICE_ROLE_KEY": "${SUPABASE_SERVICE_ROLE_KEY}",
        "REDIS_URL": "${REDIS_URL}",
        "MCP_AUTH_TOKEN": "${MCP_AUTH_TOKEN}"
      }
    }
  }
}
